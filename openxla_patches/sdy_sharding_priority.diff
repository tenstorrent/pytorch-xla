+// Try to parse priority info from xla.sdy.sharding frontend attribute.
+// Returns a vector of priorities for each dimension, or empty if not present.
+SmallVector<std::optional<int64_t>> tryParsePrioritiesFromFrontendAttr(
+    mlir::DictionaryAttr frontendAttrs, mlir::MLIRContext* ctx) {
+  SmallVector<std::optional<int64_t>> priorities;
+  if (!frontendAttrs) {
+    return priorities;
+  }
+  auto sdyShardingAttr = frontendAttrs.getAs<StringAttr>(kShardingRoundTripAttr);
+  if (!sdyShardingAttr) {
+    return priorities;
+  }
+  // Parse the SDY sharding string to extract priority info
+  auto parsed = mlir::parseAttribute(sdyShardingAttr.getValue(), ctx);
+  if (auto tensorSharding = mlir::dyn_cast_or_null<TensorShardingAttr>(parsed)) {
+    for (auto dimSharding : tensorSharding.getDimShardings()) {
+      priorities.push_back(dimSharding.getPriority());
+    }
+  }
+  return priorities;
+}
+
+// Apply priorities to a TensorShardingAttr.
+// Returns a new TensorShardingAttr with priorities applied.
+TensorShardingAttr applyPrioritiesToSharding(
+    TensorShardingAttr sharding,
+    const SmallVector<std::optional<int64_t>>& priorities,
+    mlir::MLIRContext* ctx) {
+  if (priorities.empty()) {
+    return sharding;
+  }
+  SmallVector<DimensionShardingAttr> newDimShardings;
+  auto dimShardings = sharding.getDimShardings();
+  for (size_t i = 0; i < dimShardings.size(); ++i) {
+    auto dimSharding = dimShardings[i];
+    std::optional<int64_t> priority =
+        (i < priorities.size()) ? priorities[i] : std::nullopt;
+    // Create new DimensionShardingAttr with priority
+    newDimShardings.push_back(DimensionShardingAttr::get(
+        ctx, dimSharding.getAxes(), dimSharding.getIsClosed(), priority));
+  }
+  return TensorShardingAttr::get(ctx, sharding.getMeshOrRef(),
+                                 newDimShardings, sharding.getReplicatedAxes(), sharding.getUnreducedAxes());
+}
